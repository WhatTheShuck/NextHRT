// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma_client"
}

datasource db {
  provider = "sqlite"
}

model Employee {
  id                       Int                       @id @default(autoincrement())
  legalFirstName           String
  legalLastName            String
  preferredFirstName       String?
  preferredLastName        String?
  title                    String
  startDate                DateTime
  finishDate               DateTime?
  department               Department                @relation(fields: [departmentId], references: [id])
  departmentId             Int
  location                 Location                  @relation(fields: [locationId], references: [id])
  locationId               Int
  notes                    String?
  usi                      String? //Universal Student Identifier
  isActive                 Boolean                   @default(true)
  status                   EmployeeStatus            @default(Permanent)
  // Internal/External, derived from `status` via deriveEmploymentType() (§6.2). Nullable
  // so existing rows backfill gradually; kept in sync on every create/update.
  employmentType           EmploymentType?
  jobFamily                JobFamily?                @relation(fields: [jobFamilyId], references: [id])
  jobFamilyId              Int?
  trainingRecords          TrainingRecords[]
  ticketRecords            TicketRecords[]
  trainingTicketExemptions TrainingTicketExemption[]
  User                     User?
  requirementsCacheEntries RequirementsCacheEntry[]
  nominatedApprovals       ApprovalRequest[]        @relation("NominatedApprover")
  trainingRequests         TrainingRequest[]         @relation("TrainingRequests")
}

enum EmployeeStatus {
  Permanent
  Apprentice
  LabourContractor
  IndustryExperience
  PartTimePermanent
}

// Internal vs External — derived deterministically from EmployeeStatus (§6.2).
// Internal: Permanent, PartTimePermanent. External: LabourContractor,
// IndustryExperience, Apprentice.
enum EmploymentType {
  Internal
  External
}

// Onboarding request lifecycle (§6.3). Admin gates only the Employee creation.
enum OnboardingStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

// Managed reference table (like Department/Location), admin-editable (§6.5).
// Prefill flags: null = no override; true/false = force the field to checked/unchecked when
// this job family is selected on the onboarding form.
model JobFamily {
  id                       Int                 @id @default(autoincrement())
  name                     String              @unique
  isActive                 Boolean             @default(true)
  prefillLaptop            Boolean?
  prefillIpad              Boolean?
  prefillNonStandardLaptop Boolean?
  prefillE3Licence         Boolean?
  prefillMarketingInduction Boolean?
  employees                Employee[]
  onboardingRequests       OnboardingRequest[]
}

// Pre-employment medical standards — managed table, NOT a Prisma enum (§6.6).
// Seed: KSB Standard / No / Telfer.
// Each standard carries its own email templates (manager at start date;
// employee follow-up 3 days later). Use {tokens} for interpolation.
// Empty body = no email sent for that recipient.
model MedicalStandard {
  id                   Int                 @id @default(autoincrement())
  name                 String              @unique
  isActive             Boolean             @default(true)
  managerEmailSubject  String              @default("")
  managerEmailBody     String              @default("")
  employeeEmailSubject String              @default("")
  employeeEmailBody    String              @default("")
  onboardingRequests   OnboardingRequest[]
}

// Software-access program catalogue — admin-editable reference table (§6.4).
// IT-ticket link is constructed from `ticketNumber` + a configurable base URL.
model Program {
  id                    Int      @id @default(autoincrement())
  name                  String   @unique
  ticketNumber          String? // IT ticket number (not the full URL)
  infoRequired          String? // "info required" text shown to IT
  requiresReferenceUser Boolean  @default(false)
  isActive              Boolean  @default(true)
}

// Hardware catalogue — admin-editable reference table (§6.4).
// `payloadTemplate` is the request-type/payload template for the hardware API.
model HardwareItem {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  payloadTemplate String? // JSON/template for the hardware-request platform
  isActive        Boolean  @default(true)
}

// Admin-editable email templates keyed by a stable template id (§6.7).
// Bodies support variable interpolation (preferred name, start date, etc.).
model EmailTemplate {
  id        Int      @id @default(autoincrement())
  key       String   @unique // stable template id, e.g. "manager.nextSteps.internal"
  name      String
  subject   String   @default("")
  body      String   @default("")
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// Manager-facing onboarding submission (§6.3). Hybrid storage: explicit columns for
// the core HR fields the Admin reviews/edits (→ become the Employee on approval), plus
// a JSON `payload` for the non-HR sub-objects (programs/hardware/compliance/notes).
model OnboardingRequest {
  id                Int              @id @default(autoincrement())
  status            OnboardingStatus @default(Pending)
  submittedByUserId String
  submittedByUser   User             @relation("OnboardingSubmissions", fields: [submittedByUserId], references: [id])

  // --- Core HR fields the ADMIN reviews/edits → become the Employee on approval ---
  legalFirstName     String
  legalLastName      String
  preferredFirstName String?
  preferredLastName  String?
  title              String
  departmentId       Int?
  locationId         Int?
  employmentStatus   EmployeeStatus // the hire's EmployeeStatus (named to avoid clashing with request `status`)
  employmentType     EmploymentType // derived from employmentStatus via deriveEmploymentType()
  startDate          DateTime
  // --- Pending org requests (set when user requests a new dept/location) ---
  pendingDepartmentRequestId Int?
  pendingDepartmentRequest   OrgRequest? @relation("PendingDepartmentRequest", fields: [pendingDepartmentRequestId], references: [id])
  pendingLocationRequestId   Int?
  pendingLocationRequest     OrgRequest? @relation("PendingLocationRequest", fields: [pendingLocationRequestId], references: [id])

  managerEmployeeId  Int? // who the next-steps email goes to (request-only)
  jobFamilyId        Int?
  jobFamily          JobFamily?       @relation(fields: [jobFamilyId], references: [id])
  medicalStandardId  Int?
  medicalStandard    MedicalStandard? @relation(fields: [medicalStandardId], references: [id])
  emailConfirmed     Boolean          @default(false)

  // --- Non-HR payload (NOT admin-approved; drives jobs; archived to profile) ---
  payload String // JSON: { programs[], hardware[], compliance{}, notes{it,hr,payroll} }

  // --- Lifecycle ---
  createdEmployeeId Int? // set on approval
  reviewedByUserId  String?
  reviewedAt        DateTime?
  reviewNotes       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
}

enum OrgRequestType {
  Department
  Location
}

enum OrgRequestStatus {
  Pending
  Approved
  Rejected
}

model OrgRequest {
  id               Int             @id @default(autoincrement())
  type             OrgRequestType
  requestedData    String          // JSON: dept { name, parentDepartmentId? } | location { name, state }
  status           OrgRequestStatus @default(Pending)
  note             String?
  requestedByUserId String
  requestedByUser  User            @relation("OrgRequests", fields: [requestedByUserId], references: [id])
  reviewedByUserId String?
  reviewedByUser   User?           @relation("OrgRequestReviews", fields: [reviewedByUserId], references: [id])
  reviewedAt       DateTime?
  createdDepartmentId Int?
  createdLocationId   Int?
  createdAt        DateTime        @default(now())

  onboardingAsDepartment OnboardingRequest[] @relation("PendingDepartmentRequest")
  onboardingAsLocation   OnboardingRequest[] @relation("PendingLocationRequest")

  @@index([status])
}

model Location {
  id       Int     @id @default(autoincrement())
  name     String
  state    String
  isActive Boolean @default(true)

  employees            Employee[]
  trainingRequirements TrainingRequirement[]
  ticketRequirements   TicketRequirement[]

  @@unique([name, state])
}

model Department {
  id                 Int          @id @default(autoincrement())
  name               String       @unique
  isActive           Boolean      @default(true)
  // Self-referential relationship for tiered departments
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  parentDepartmentId Int?
  childDepartments   Department[] @relation("DepartmentHierarchy")

  // Computed field to determine hierarchy level (0 = root, 1 = first level, etc.)
  level Int @default(0)

  employees            Employee[]
  managers             User[]                @relation("DepartmentManager")
  trainingRequirements TrainingRequirement[]
  ticketRequirements   TicketRequirement[]
}

model Training {
  id                 Int                       @id @default(autoincrement())
  category           Category
  title              String
  isActive           Boolean                   @default(true)
  trainingRecords         TrainingRecords[]
  requirements            TrainingRequirement[]
  trainingExemptions      TrainingTicketExemption[]
  trainingRequestLinks    TrainingRequest[]          @relation("TrainingRequestTraining")
  resolvedCourseRequests  TrainingCourseRequest[]    @relation("ResolvedTraining")
}

model TrainingRecords {
  id            Int             @id @default(autoincrement())
  personTrained Employee        @relation(fields: [employeeId], references: [id])
  employeeId    Int
  dateCompleted DateTime
  training      Training        @relation(fields: [trainingId], references: [id])
  trainingId    Int
  trainer       String
  images        TrainingImage[]

  @@unique([employeeId, trainingId, dateCompleted])
}

model TrainingImage {
  id              Int             @id @default(autoincrement())
  trainingRecord  TrainingRecords @relation(fields: [trainingRecordId], references: [id], onDelete: Cascade)
  trainingRecordId Int
  imagePath       String
  imageType       String
  originalName    String
  uploadedAt      DateTime        @default(now())

  @@index([trainingRecordId])
}

model TrainingRequirement {
  trainingId   Int
  departmentId Int
  locationId   Int
  training     Training   @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([trainingId, departmentId, locationId])
  @@index([departmentId])
  @@index([locationId])
}

enum Category {
  Internal
  External
  SOP
}

model Ticket {
  id               Int                       @id @default(autoincrement())
  ticketCode       String
  ticketName       String
  renewal          Int? // in years
  isActive         Boolean                   @default(true)
  ticketRecords    TicketRecords[]
  requirements     TicketRequirement[]
  ticketExemptions TrainingTicketExemption[]
}

model TicketRecords {
  id            Int           @id @default(autoincrement())
  ticketHolder  Employee      @relation(fields: [employeeId], references: [id])
  employeeId    Int
  dateIssued    DateTime
  ticket        Ticket        @relation(fields: [ticketId], references: [id])
  ticketId      Int
  licenseNumber String? // Optional unique number for the actual license instance
  expiryDate    DateTime?
  expiryNotificationStage String? // null | "WarnSent" | "ExpiredSent" — idempotency anchor for the TICKET_EXPIRY job (spec §5.5). NOT compliance state.
  images        TicketImage[]

  @@index([employeeId])
  @@index([ticketId])
}

model TicketImage {
  id             Int           @id @default(autoincrement())
  ticketRecord   TicketRecords @relation(fields: [ticketRecordId], references: [id], onDelete: Cascade)
  ticketRecordId Int
  imagePath      String
  imageType      String
  originalName   String
  uploadedAt     DateTime      @default(now())

  @@index([ticketRecordId])
}

model TicketRequirement {
  ticketId     Int
  departmentId Int
  locationId   Int
  ticket       Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([ticketId, departmentId, locationId])
  @@index([departmentId])
  @@index([locationId])
}

model TrainingTicketExemption {
  id         Int             @id @default(autoincrement())
  employee   Employee        @relation(fields: [employeeId], references: [id])
  employeeId Int
  type       ExemptionType // Training or Ticket
  training   Training?       @relation(fields: [trainingId], references: [id])
  trainingId Int? // Only populated if type is Training
  ticket     Ticket?         @relation(fields: [ticketId], references: [id])
  ticketId   Int? // Only populated if type is Ticket
  reason     String // Why they're exempted
  startDate  DateTime        @default(now()) // When exemption starts
  endDate    DateTime? // Optional: When exemption expires
  status     ExemptionStatus @default(Active)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

enum ExemptionType {
  Training
  Ticket
}

enum ExemptionStatus {
  Active
  Expired
  Revoked
}

model History {
  id            Int      @id @default(autoincrement())
  tableName     String // Which table was affected (Employee, Training, etc.)
  recordId      String // ID of the record that was changed
  action        String // CREATE, UPDATE, DELETE
  changedFields String? // JSON string of changed fields
  oldValues     String? // JSON string of previous values
  newValues     String? // JSON string of new values
  userId        String? // Foreign key to User model
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  timestamp     DateTime @default(now()) // When the change occurred
}

model User {
  id                           String        @id @default(cuid())
  name                         String?
  email                        String?       @unique
  emailVerified                Boolean?
  image                        String?
  role                         UserRole?     @default(User)
  receivesExpiryNotifications  Boolean       @default(true) // opt-out: admins receive ticket-expiry emails unless they turn this off (spec §5.6)
  banned                       Boolean?      // better-auth admin plugin
  banReason                    String?       // better-auth admin plugin
  banExpires                   DateTime?     // better-auth admin plugin
  managedDepartments           Department[]  @relation("DepartmentManager")
  canManageChildrenDepartments Boolean       @default(false) // Can manage child departments
  employee                     Employee?     @relation(fields: [employeeId], references: [id])
  employeeId                   Int?          @unique // Link to employee if user represents an employee
  accounts                     Account[]
  sessions                     Session[]
  historyLogs                  History[]
  appSettingUpdates            AppSetting[]
  themeId                      String?
  theme                        Theme?        @relation("UserActiveTheme", fields: [themeId], references: [id], onDelete: SetNull)
  themes                       Theme[]                @relation("UserThemes")
  submittedApprovals           ApprovalRequest[]      @relation("SubmittedApprovals")
  onboardingRequests           OnboardingRequest[]    @relation("OnboardingSubmissions")
  orgRequests                  OrgRequest[]           @relation("OrgRequests")
  orgRequestReviews            OrgRequest[]           @relation("OrgRequestReviews")
  approvalActions              ApprovalAction[]       @relation("ApprovalActions")
  courseRequests               TrainingCourseRequest[] @relation("CourseRequests")
  apiKeys                      Apikey[]
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
}

model AppSetting {
  key           String   @id
  value         String
  description   String?
  updatedAt     DateTime @updatedAt
  updatedBy     String?
  updatedByUser User?    @relation(fields: [updatedBy], references: [id], onDelete: SetNull)
}

enum ThemeType {
  BUILTIN
  COMPANY
  USER
}

model Theme {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  type         ThemeType
  cssVars      Json
  darkCssVars  Json?
  userId       String?
  user         User?     @relation("UserThemes", fields: [userId], references: [id], onDelete: SetNull)
  activeForUsers User[]  @relation("UserActiveTheme")
  createdAt    DateTime  @default(now())
}

enum UserRole {
  User
  DepartmentManager
  FireWarden
  Admin
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  providerId           String    @map("provider") // Map your existing `provider` field to Better Auth's `providerId`
  accountId            String    @map("providerAccountId")
  refreshToken         String?   @map("refresh_token")
  accessToken          String?   @map("access_token")
  accessTokenExpiresAt DateTime? @map("expires_at")
  scope                String?
  idToken              String?   @map("id_token")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime @map("expires") // Map your existing `expires` field to Better Auth's `expiresAt`
  token     String   @unique @map("sessionToken") // Map your existing `sessionToken` field to Better Auth's `token`
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

enum ApprovalStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

enum ApprovalStage {
  DepartmentManager
  HRManager
  Admin
}

enum ApprovalDecision {
  Approved
  Rejected
}

enum ApprovalRequestType {
  Training
}

enum TrainingCourseRequestStatus {
  Pending
  Approved
  Rejected
}

enum AppLogSeverity {
  Info
  Warning
  Error
}

enum JobType {
  EXEMPTION_EXPIRY
  TICKET_EXPIRY
  REQUIREMENTS_CACHE_REBUILD
  REQUIREMENTS_CACHE_INVALIDATE
  INACTIVE_EMPLOYEE_CHECK
  ORPHANED_IMAGE_CLEANUP
  HISTORY_ARCHIVAL
  REEVALUATE_PENDING_APPROVALS
  SEND_EMAIL
  HARDWARE_REQUEST
}

enum JobStatus {
  Pending
  Running
  Completed
  Failed
  Cancelled
}

enum CacheItemType {
  Training
  Ticket
}

model BackgroundJob {
  id            Int       @id @default(autoincrement())
  type          JobType
  status        JobStatus @default(Pending)
  payload       String?   // JSON string
  resultSummary String?   // JSON string
  errorMessage  String?
  attempts      Int       @default(0) // number of failed attempts so far
  scheduledAt   DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, scheduledAt])
  @@index([type])
}

model ApprovalRequest {
  id                          Int                 @id @default(autoincrement())
  requestType                 ApprovalRequestType
  status                      ApprovalStatus      @default(Pending)
  currentStage                ApprovalStage       @default(DepartmentManager)
  nominatedApproverEmployeeId Int?
  nominatedApproverEmployee   Employee?           @relation("NominatedApprover", fields: [nominatedApproverEmployeeId], references: [id])
  submittedByUserId           String
  submittedByUser             User                @relation("SubmittedApprovals", fields: [submittedByUserId], references: [id])
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt

  actions         ApprovalAction[]
  trainingRequest TrainingRequest?
}

model ApprovalAction {
  id         Int              @id @default(autoincrement())
  requestId  Int
  request    ApprovalRequest  @relation(fields: [requestId], references: [id])
  stage      ApprovalStage
  userId     String
  user       User             @relation("ApprovalActions", fields: [userId], references: [id])
  decision   ApprovalDecision
  comment    String?
  onBehalfOf Boolean          @default(false)
  createdAt  DateTime         @default(now())
}

model TrainingRequest {
  id                      Int                    @id @default(autoincrement())
  approvalRequestId       Int                    @unique
  approvalRequest         ApprovalRequest        @relation(fields: [approvalRequestId], references: [id])
  employeeId              Int
  employee                Employee               @relation("TrainingRequests", fields: [employeeId], references: [id])
  trainingId              Int?
  training                Training?              @relation("TrainingRequestTraining", fields: [trainingId], references: [id])
  trainingCourseRequestId Int?
  trainingCourseRequest   TrainingCourseRequest? @relation(fields: [trainingCourseRequestId], references: [id])
  justification           String?
  cost                    Float?
  hours                   Float?
  trainingDate            DateTime?
  intendedCompletionDate  DateTime?
  createdAt               DateTime               @default(now())
}

model TrainingCourseRequest {
  id                 Int                         @id @default(autoincrement())
  name               String
  description        String?
  requestedByUserId  String
  requestedByUser    User                        @relation("CourseRequests", fields: [requestedByUserId], references: [id])
  status             TrainingCourseRequestStatus @default(Pending)
  resolvedTrainingId Int?
  resolvedTraining   Training?                   @relation("ResolvedTraining", fields: [resolvedTrainingId], references: [id])
  createdAt          DateTime                    @default(now())

  trainingRequests TrainingRequest[]
}

model AppLog {
  id        Int            @id @default(autoincrement())
  message   String
  severity  AppLogSeverity @default(Info)
  source    String?
  createdAt DateTime       @default(now())
}

model RequirementsCacheEntry {
  id         Int           @id @default(autoincrement())
  employeeId Int
  itemType   CacheItemType
  itemId     Int
  updatedAt  DateTime      @updatedAt

  employee   Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, itemType, itemId])
  @@index([employeeId])
  @@index([itemType, itemId])
}

model Apikey {
  id                  String    @id @default(cuid())
  configId            String    @default("default")
  name                String?
  start               String?
  referenceId         String
  prefix              String?
  key                 String    @unique
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean   @default(true)
  rateLimitEnabled    Boolean   @default(true)
  rateLimitTimeWindow Int?      @default(86400000)
  rateLimitMax        Int?      @default(10)
  requestCount        Int       @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  permissions         String?
  metadata            String?
  user                User      @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([referenceId])
  @@index([key])
  @@map("apikey")
}
